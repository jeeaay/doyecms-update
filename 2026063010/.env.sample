# DoyeCMS 环境变量配置示例
# 复制此文件为 .env 并根据需要修改配置

# 调试模式 (true/false/1/0/on/off/yes/no)
# 开发环境建议设为 true，生产环境建议设为 false
# 支持以下值: true, 1, on, yes 表示开启; false, 0, off, no 表示关闭
DEBUG_MODE=true

# 通用缓存驱动
# 可选值: memcache, redis, file
# 未设置时默认使用 memcache
CACHE_HANDLER=memcache

# Memcache 连接配置
# 当 config/config.php 中的 cache.handler 设为 memcache 时生效
MEMCACHE_HOST=127.0.0.1
MEMCACHE_PORT=11211

# Redis 连接配置
# 当 config/config.php 中的 cache.handler 设为 redis 时生效
# 默认连接 127.0.0.1:6379，数据库 db0
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TIMEOUT=3600
REDIS_PREFIX=doye:

# 文件缓存路径
# 当 config/config.php 中的 cache.handler 设为 file 时生效
# 未设置时默认使用 runtime/cache/data
FILE_CACHE_PATH=runtime/cache/data

# 真实客户端 IP 识别
# 直连站建议保持 false，仅使用 REMOTE_ADDR
# ESA/可信代理站点可设为 true，并通过 TRUSTED_IP_HEADERS 指定可信头
# 若同时配置 TRUSTED_PROXY_AUTH_SECRET，则只有回源认证通过才信任这些头
TRUSTED_PROXY_ENABLE=false
# 允许设置多个 如ALI_REAL_CLIENT_IP,X_DCMS_REAL_IP
TRUSTED_IP_HEADERS=ALI_REAL_CLIENT_IP
TRUSTED_PROXY_AUTH_HEADER=CDN_SRC_SEC
TRUSTED_PROXY_AUTH_SECRET=8f4c2d91b7a64e5fa3c0d2e8b1f9746a

# 数据库名称
# SQLite 可填写数据库文件路径，MySQL 可填写数据库名
# 未设置时保持 config/database.php 中的默认值
DB_NAME=/data/doye_tvOqSSX02XCKyYPI.db
